# Watcher Protocol Configuration

# Application
APP_NAME=Watcher Protocol
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql+asyncpg://watcher:watcher_password@localhost:5432/watcher_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Object Storage (MinIO/S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=watcher-content

# AI/ML
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
CLASSIFICATION_MODEL=distilbert-base-uncased

# Scrapers
ARXIV_API_URL=http://export.arxiv.org/api/query
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.CY
ARXIV_SCRAPE_INTERVAL_MINUTES=60

GITHUB_TOKEN=your_github_token_here
GITHUB_SCRAPE_INTERVAL_MINUTES=120

RSS_FEEDS=https://www.alignmentforum.org/feed.xml,https://www.lesswrong.com/feed.xml
RSS_SCRAPE_INTERVAL_MINUTES=30

# Notifications
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@watcherprotocol.com

SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Alerts
ENABLE_NOTIFICATIONS=true
ALERT_BATCH_INTERVAL_MINUTES=15
MAX_ALERTS_PER_BATCH=50

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
SCRAPER_RATE_LIMIT=30

# Monitoring
ENABLE_PROMETHEUS=true
ENABLE_SENTRY=false
SENTRY_DSN=

# Security
API_KEYS=
SECRET_KEY=change-me-in-production-to-a-random-secure-key
